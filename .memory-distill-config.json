{
  "version": "2.0.0",
  "description": "记忆自动提炼系统配置（简化版）",
  "paths": {
    "memory_root": "memory",
    "private_dir": "memory/private",
    "work_dir": "memory/work",
    "daily_dir": "memory/daily",
    "archive_dir": "memory/archive",
    "log_dir": "memory/logs"
  },
  "targets": {
    "strategic": {
      "level": "战略级",
      "description": "影响方向的核心决策、长期规划、重大资源调配",
      "destination": "memory/private/STRATEGY.md",
      "section": "## 战略记忆"
    },
    "normative": {
      "level": "规范级",
      "description": "流程规范、标准定义、最佳实践",
      "destination": "memory/work/PROJECT.md",
      "section": "## 工作规范"
    },
    "temporary": {
      "level": "临时级",
      "description": "当日临时事项、待办、短期提醒（不写入长期记忆）",
      "retention_days": 7
    }
  },
  "classification": {
    "model": "moonshot/kimi-k2.5",
    "prompt_template": "请分析以下工作日志内容，判断其重要性级别。\n\n内容：{content}\n\n请按以下标准分类：\n- 战略级：影响方向的核心决策、长期规划、重大变更\n- 规范级：流程规范、标准定义、最佳实践\n- 临时级：当日临时事项、待办、短期提醒\n\n请以JSON格式返回：{\"level\": \"战略级|规范级|临时级\", \"confidence\": 0-1, \"keywords\": [\"关键词1\", \"关键词2\"], \"summary\": \"一句话摘要\"}"
  },
  "deduplication": {
    "enabled": true,
    "similarity_threshold": 0.85,
    "hash_algorithm": "md5"
  },
  "archival": {
    "enabled": true,
    "retention_days": 30,
    "compress": false
  },
  "audit": {
    "enabled": true,
    "log_level": "INFO",
    "log_file": "memory/logs/distill.log",
    "report_day": "sunday",
    "report_file": "memory/logs/weekly-report.md"
  },
  "trust": {
    "mode": "auto",
    "auto_write": true,
    "require_approval": false,
    "high_risk_keywords": ["删除", "移除", "废弃", "重构", "重大变更", "迁移", "下线"],
    "require_approval_threshold": 0.8,
    "approval_by": "阿九",
    "report_detail_level": "summary",
    "important_levels": ["战略级"]
  },
  "filtering": {
    "skip_patterns": [
      "^# .{1,20}工作日志",
      "^## 今日任务",
      "^## 明日计划",
      "^- \\[ \\].*待办",
      "^---$",
      "^## 工作日志.*"
    ],
    "min_content_length": 30,
    "max_content_length": 1000,
    "require_verifiable": true,
    "skip_fictional_scenarios": true
  },
  "reporting": {
    "show_full_content_for": ["战略级"],
    "show_summary_for": ["规范级"],
    "max_preview_length": 300
  }
}